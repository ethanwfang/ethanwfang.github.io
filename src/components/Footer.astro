<footer id="contact" class="footer">
  <div class="footer__inner">
    <ul class="footer__icons">
      <li>
        <a href="https://github.com/ethanwfang" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.3 1.19-3.1-.12-.3-.52-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.2-1.5 3.17-1.18 3.17-1.18.64 1.6.24 2.77.12 3.07.74.8 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/>
          </svg>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/ethanwfang" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.7h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.15V21H18.6v-5.5c0-1.31-.02-3-1.83-3-1.83 0-2.11 1.43-2.11 2.9V21H10V9Z"/>
          </svg>
        </a>
      </li>
    </ul>
    <p class="footer__copy">© {new Date().getFullYear()} Ethan Fang</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 2rem 0;
    border-top: 1px solid var(--rule);
  }
  .footer__inner {
    width: min(100% - 2.5rem, 1200px);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .footer__icons {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
  }
  .footer__icons a {
    color: var(--muted);
    background-image: none;
    display: inline-flex;
    transition: color 180ms ease, transform 180ms ease;
  }
  .footer__icons a:hover { color: var(--accent); transform: translateY(-2px); }
  .footer__copy {
    color: var(--muted);
    font-size: var(--step--1);
    margin: 0;
  }
</style>
