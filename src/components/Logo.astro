---
interface Props {
  domain?: string;
  mark?: string;
  alt: string;
}
const { domain, mark, alt } = Astro.props;
const src = domain ? `https://www.google.com/s2/favicons?domain=${domain}&sz=128` : null;
const initials = (mark ?? alt).trim().slice(0, 2).toUpperCase();
---

{src ? (
  <span class="logo logo--img" aria-hidden="true">
    <img src={src} alt="" width="40" height="40" loading="lazy" />
  </span>
) : (
  <span class="logo logo--mark" aria-hidden="true">{initials}</span>
)}

<style>
  .logo {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    overflow: hidden;
  }
  .logo--img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
  }
  .logo--mark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
</style>
